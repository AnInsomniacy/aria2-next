#!/bin/sh
set -eu

usage() {
  echo "Usage: $0 <platform> <binary>" >&2
  echo "Platforms: linux, macos, windows-x86_64, windows-arm64, android-arm64" >&2
  exit 2
}

test $# -eq 2 || usage

platform=$1
binary=$2

if [ ! -f "$binary" ]; then
  echo "Runtime dependency check failed: binary not found: $binary" >&2
  exit 1
fi

tmp=${TMPDIR:-/tmp}/aria2-runtime-deps.$$
deps_tmp=$tmp.deps
strings_tmp=$tmp.strings
trap 'rm -f "$deps_tmp" "$strings_tmp"' EXIT HUP INT TERM

fail_unexpected() {
  dep=$1
  echo "Unexpected runtime dependency for $platform: $dep" >&2
  exit 1
}

check_windows() {
  command -v objdump >/dev/null 2>&1 || {
    echo "Runtime dependency check failed: objdump is required for Windows binaries" >&2
    exit 1
  }

  objdump -p "$binary" |
    awk '/^[[:space:]]*DLL Name:/ {
      sub(/^[[:space:]]*DLL Name:[[:space:]]*/, "")
      print
    }' |
    sort -fu > "$deps_tmp"

  while IFS= read -r dep; do
    dep_lc=$(printf '%s\n' "$dep" | tr '[:upper:]' '[:lower:]')
    case "$dep_lc" in
      api-ms-win-crt-private-*.dll)
        fail_unexpected "$dep"
        ;;
      api-ms-win-*.dll|advapi32.dll|bcrypt.dll|cfgmgr32.dll|crypt32.dll|dnsapi.dll|gdi32.dll|iphlpapi.dll|kernel32.dll|msvcrt.dll|mswsock.dll|normaliz.dll|ntdll.dll|ole32.dll|oleaut32.dll|psapi.dll|rpcrt4.dll|secur32.dll|shell32.dll|shlwapi.dll|ucrtbase.dll|user32.dll|version.dll|winmm.dll|ws2_32.dll|wsock32.dll)
        ;;
      *)
        fail_unexpected "$dep"
        ;;
    esac
  done < "$deps_tmp"
}

check_elf() {
  reader=${READELF:-readelf}
  command -v "$reader" >/dev/null 2>&1 || {
    echo "Runtime dependency check failed: $reader is required for ELF binaries" >&2
    exit 1
  }

  "$reader" -d "$binary" |
    awk '
      /Shared library:/ {
        dep = $0
        sub(/^.*Shared library: \[/, "", dep)
        sub(/\].*$/, "", dep)
        print dep
      }
      /\(NEEDED\)/ {
        dep = $0
        sub(/^.*\[/, "", dep)
        sub(/\].*$/, "", dep)
        print dep
      }
    ' |
    sort -fu > "$deps_tmp"

  if [ "$platform" = linux ]; then
    if [ -s "$deps_tmp" ]; then
      dep=$(sed -n '1p' "$deps_tmp")
      fail_unexpected "$dep"
    fi

    if "$reader" -l "$binary" | grep -q 'Requesting program interpreter'; then
      fail_unexpected "ELF interpreter"
    fi

    command -v strings >/dev/null 2>&1 || {
      echo "Runtime dependency check failed: strings is required for Linux ELF binaries" >&2
      exit 1
    }

    strings "$binary" > "$strings_tmp"
    if grep -F -q -e 'libnss_' -e '__nss_' -e 'GNU C Library' -e 'ld-linux' "$strings_tmp"; then
      fail_unexpected "static glibc/NSS marker"
    fi

    return
  fi

  while IFS= read -r dep; do
    case "$platform:$dep" in
      android-arm64:libc.so|android-arm64:libdl.so|android-arm64:liblog.so|android-arm64:libm.so)
        ;;
      *)
        fail_unexpected "$dep"
        ;;
    esac
  done < "$deps_tmp"
}

check_macos() {
  command -v otool >/dev/null 2>&1 || {
    echo "Runtime dependency check failed: otool is required for macOS binaries" >&2
    exit 1
  }

  otool -L "$binary" |
    awk 'NR > 1 {
      dep = $1
      print dep
    }' |
    sort -fu > "$deps_tmp"

  while IFS= read -r dep; do
    case "$dep" in
      /System/Library/Frameworks/*|/usr/lib/*)
        ;;
      *)
        fail_unexpected "$dep"
        ;;
    esac
  done < "$deps_tmp"
}

case "$platform" in
  windows-x86_64|windows-arm64)
    check_windows
    ;;
  linux)
    check_elf
    ;;
  android-arm64)
    check_elf
    ;;
  macos)
    check_macos
    ;;
  *)
    usage
    ;;
esac

echo "Runtime dependency check passed for $platform: $binary"
